// Atomic-UI Database Schema
// Advanced Outline VPN Management Platform
// Author: sankahchan
//
// Note: SQLite doesn't support native enums, so we use String types
// with application-level validation instead. Valid values are documented
// in comments for each field.

generator client {
  provider      = "prisma-client-js"
  // Binary targets for different platforms:
  // - native: Current development machine
  // - darwin-arm64: macOS Apple Silicon
  // - debian-openssl-3.0.x: Ubuntu 22.04+ / Debian 12+
  // - linux-musl-openssl-3.0.x: Alpine Linux
  binaryTargets = ["native", "darwin-arm64", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// Authentication & Users
// ============================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String? // Nullable for passwordless/magic link flow if we go that route
  role           String   @default("USER") // Valid: ADMIN, USER
  telegramChatId String? // Telegram chat ID for bot notifications
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  accessKeys         AccessKey[]
  dynamicAccessKeys  DynamicAccessKey[]
  telegramLinkTokens TelegramLinkToken[]
  reviewedTelegramOrders TelegramOrder[]
  reviewedTelegramPremiumSupportRequests TelegramPremiumSupportRequest[] @relation("ReviewedTelegramPremiumSupportRequests")
  sessions           Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// Server Management
// ============================================

model Server {
  id                 String    @id @default(cuid())
  name               String
  apiUrl             String
  apiCertSha256      String
  location           String?
  countryCode        String?
  isDefault          Boolean   @default(false)
  isActive           Boolean   @default(true)
  maxKeys            Int?
  lifecycleMode      String    @default("ACTIVE") // ACTIVE, DRAINING, MAINTENANCE
  lifecycleNote      String?
  lifecycleChangedAt DateTime?
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  tags         ServerTag[]
  accessKeys   AccessKey[]
  healthCheck  HealthCheck?
  metrics      ServerMetric[]
  keyTemplates KeyTemplate[]

  // Cached server info from Outline API
  outlineServerId       String?
  outlineName           String?
  outlineVersion        String?
  hostnameForAccessKeys String?
  portForNewAccessKeys  Int?
  metricsEnabled        Boolean   @default(true)
  lastSyncAt            DateTime?
}

model Tag {
  id          String      @id @default(cuid())
  name        String      @unique
  color       String      @default("#06b6d4") // Cyan default
  description String?
  servers     ServerTag[]
  createdAt   DateTime    @default(now())
}

model ServerTag {
  serverId String
  tagId    String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([serverId, tagId])
}

// ============================================
// Access Key Management
// ============================================

model AccessKey {
  id           String  @id @default(cuid())
  outlineKeyId String // ID from Outline API
  name         String
  email        String?
  telegramId   String?
  notes        String?

  // User Ownership
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Server relation
  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  // Access key details from Outline
  accessUrl String?
  password  String?
  port      Int?
  method    String?

  // Traffic limits (in bytes)
  dataLimitBytes BigInt?
  usedBytes      BigInt  @default(0)

  // Periodic Data Limits
  // Strategy: DAILY, WEEKLY, MONTHLY, NEVER
  dataLimitResetStrategy String    @default("NEVER")
  lastDataLimitReset     DateTime?
  usageOffset            BigInt    @default(0) // Total usage at start of period

  // Expiration settings
  // Valid expirationType: NEVER, FIXED_DATE, DURATION_FROM_CREATION, START_ON_FIRST_USE
  expirationType String    @default("NEVER")
  expiresAt      DateTime?
  durationDays   Int? // For START_ON_FIRST_USE

  // Status tracking
  // Valid status: ACTIVE, DISABLED, EXPIRED, DEPLETED, PENDING
  status                 String    @default("ACTIVE")
  firstUsedAt            DateTime?
  lastTrafficAt          DateTime?
  lastUsedAt             DateTime?
  lastWarningSentAt      DateTime?
  expirationWarningStage String?

  // Bandwidth alerts & auto-disable
  bandwidthAlertAt80 Boolean @default(false) // true if 80% alert already sent
  bandwidthAlertAt90 Boolean @default(false) // true if 90% alert already sent
  autoDisableOnLimit Boolean @default(true) // auto-disable when 100% reached
  quotaAlertThresholds String @default("80,90") // CSV thresholds for quota notifications
  quotaAlertsSent      String @default("[]") // JSON array of thresholds already sent

  // Disable tracking - when DISABLED, key is deleted from Outline server
  // but kept in DB for potential re-enabling
  disabledAt           DateTime?
  disabledOutlineKeyId String? // Original Outline key ID when disabled (for reference)
  autoDisableOnExpire  Boolean @default(true)
  autoArchiveAfterDays Int     @default(0)
  archiveAfterAt       DateTime?
  autoRenewPolicy      String  @default("NONE") // NONE, EXTEND_DURATION
  autoRenewDurationDays Int?

  // Dynamic key association
  dynamicKeyId String?
  dynamicKey   DynamicAccessKey? @relation(fields: [dynamicKeyId], references: [id], onDelete: SetNull)

  // Prefix for obfuscation
  prefix String?

  // Subscription
  subscriptionToken String? @unique
  publicSlug        String? @unique

  // Subscription page theme (overrides global default)
  // Valid themes: dark, light, purple, blue, green, orange, pink, red
  subscriptionTheme String?

  // Subscription page cover image
  // coverImageType: upload, unsplash, gradient, url
  coverImageType String?
  coverImage     String? // Path for upload, URL for unsplash/url, gradient name for gradient

  // Contact links for subscription page (JSON array of up to 3 contacts)
  // Format: [{"type": "telegram", "value": "https://t.me/user"}, ...]
  // Valid types: telegram, discord, whatsapp, phone, email, website, facebook
  contactLinks               String?
  subscriptionWelcomeMessage String?
  sharePageEnabled           Boolean @default(true)
  clientLinkEnabled          Boolean @default(true)
  telegramDeliveryEnabled    Boolean @default(true)
  sharePagePasswordHash      String?
  sharePageAccessExpiresAt   DateTime?
  serverChangeCount          Int      @default(0)
  serverChangeLimit          Int      @default(3)
  lastServerChangeAt         DateTime?

  // Connection/device tracking
  estimatedDevices Int @default(0)
  peakDevices      Int @default(0)

  // Ownership and tagging
  owner String? // Owner/email for this key
  tags  String  @default("") // Comma-separated tags

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  trafficLogs            TrafficLog[]
  notifications          NotificationLog[]
  notificationDeliveries NotificationDelivery[]
  sessions               ConnectionSession[]
  telegramLinkTokens     TelegramLinkToken[]
  subscriptionEvents     SubscriptionPageEvent[]
  slugHistory            AccessKeySlugHistory[]
  distributionLinks      AccessDistributionLink[]
  telegramServerChangeRequests TelegramServerChangeRequest[]

  @@unique([serverId, outlineKeyId])
  @@index([status])
  @@index([status, lastTrafficAt])
  @@index([expiresAt])
  @@index([userId])
  @@index([serverId])
}

model TelegramOrder {
  id                   String   @id @default(cuid())
  orderCode            String   @unique
  kind                 String
  status               String
  telegramChatId       String
  telegramUserId       String
  telegramUsername     String?
  locale               String   @default("en")
  requestedName        String?
  requestedEmail       String?
  planCode             String?
  planName             String?
  priceAmount          Int?
  priceCurrency        String?
  priceLabel           String?
  durationMonths       Int?
  durationDays         Int?
  dataLimitBytes       BigInt?
  unlimitedQuota       Boolean  @default(false)
  templateId           String?
  dynamicTemplateId    String?
  deliveryType         String   @default("ACCESS_KEY")
  selectedServerId     String?
  selectedServerName   String?
  selectedServerCountryCode String?
  paymentMethodCode    String?
  paymentMethodLabel   String?
  paymentMethodAccountName String?
  paymentMethodAccountNumber String?
  targetAccessKeyId    String?
  targetDynamicKeyId   String?
  approvedAccessKeyId  String?
  approvedDynamicKeyId String?
  paymentProofFileId   String?
  paymentProofType     String?
  paymentProofRevision Int      @default(0)
  paymentMessageId     Int?
  paymentCaption       String?
  paymentStageEnteredAt DateTime?
  paymentReminderSentAt DateTime?
  reviewReminderSentAt  DateTime?
  paymentSubmittedAt   DateTime?
  expiredAt            DateTime?
  adminNote            String?
  customerMessage      String?
  rejectionReasonCode  String?
  reviewedByUserId     String?
  reviewedBy           User?    @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt           DateTime?
  fulfilledAt          DateTime?
  rejectedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([telegramChatId, status, createdAt])
  @@index([telegramUserId, status, createdAt])
  @@index([status, createdAt])
  @@index([reviewedByUserId, status])
}

model TelegramServerChangeRequest {
  id                         String   @id @default(cuid())
  requestCode                String   @unique
  status                     String
  locale                     String   @default("en")
  telegramChatId             String
  telegramUserId             String
  telegramUsername           String?
  accessKeyId                String
  accessKey                  AccessKey @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  currentServerId            String
  currentServerName          String
  currentServerCountryCode   String?
  requestedServerId          String
  requestedServerName        String
  requestedServerCountryCode String?
  adminNote                  String?
  customerMessage            String?
  reviewedByUserId           String?
  reviewerName               String?
  reviewedAt                 DateTime?
  fulfilledAt                DateTime?
  rejectedAt                 DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([telegramChatId, status, createdAt])
  @@index([telegramUserId, status, createdAt])
  @@index([accessKeyId, status, createdAt])
  @@index([status, createdAt])
}

model TelegramPremiumSupportRequest {
  id                           String   @id @default(cuid())
  requestCode                  String   @unique
  status                       String
  requestType                  String
  locale                       String   @default("en")
  telegramChatId               String
  telegramUserId               String
  telegramUsername             String?
  dynamicAccessKeyId           String
  dynamicAccessKey             DynamicAccessKey @relation(fields: [dynamicAccessKeyId], references: [id], onDelete: Cascade)
  requestedRegionCode          String?
  currentPoolSummary           String?
  currentResolvedServerId      String?
  currentResolvedServerName    String?
  currentResolvedServerCountryCode String?
  appliedPinServerId           String?
  appliedPinServerName         String?
  appliedPinExpiresAt          DateTime?
  adminNote                    String?
  customerMessage              String?
  reviewedByUserId             String?
  reviewedBy                   User?    @relation("ReviewedTelegramPremiumSupportRequests", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewerName                 String?
  reviewedAt                   DateTime?
  handledAt                    DateTime?
  dismissedAt                  DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([telegramChatId, status, createdAt])
  @@index([telegramUserId, status, createdAt])
  @@index([dynamicAccessKeyId, status, createdAt])
  @@index([status, requestType, createdAt])
}

model TelegramUserProfile {
  telegramUserId String   @id
  telegramChatId String?
  username       String?
  displayName    String?
  locale         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([telegramChatId])
}

model DynamicAccessKey {
  id   String @id @default(cuid())
  name String
  type String @default("SELF_MANAGED") // Valid: SELF_MANAGED, MANUAL

  // Contact information (for tracking/notification purposes)
  email      String?
  telegramId String?
  notes      String?

  // User Ownership
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // For tag-based server selection (stored as JSON string)
  serverTagsJson String @default("[]")

  // Limits
  dataLimitBytes BigInt?
  usedBytes      BigInt  @default(0)

  // Periodic Limits
  dataLimitResetStrategy String    @default("NEVER")
  lastDataLimitReset     DateTime?
  usageOffset            BigInt    @default(0)

  expiresAt      DateTime?
  durationDays   Int?
  expirationType String    @default("NEVER") // Same values as AccessKey

  // Status
  status        String    @default("ACTIVE") // Same values as AccessKey
  firstUsedAt   DateTime?
  lastTrafficAt DateTime?

  // Dynamic URL
  dynamicUrl String? @unique
  publicSlug String? @unique

  // Protocol obfuscation prefix (for protocol obfuscation)
  prefix String?

  // Encryption method for Shadowsocks
  method String @default("chacha20-ietf-poly1305")

  // Ownership and tagging
  owner String? // Owner/email for this key
  tags  String  @default("") // Comma-separated tags

  // Load balancer algorithm for selecting access keys
  // Valid: IP_HASH, RANDOM, ROUND_ROBIN, LEAST_LOAD
  loadBalancerAlgorithm String @default("IP_HASH")

  // Dynamic routing preferences
  preferredServerIdsJson   String @default("[]")
  preferredCountryCodesJson String @default("[]")
  preferredServerWeightsJson String @default("{}")
  preferredCountryWeightsJson String @default("{}")
  preferredRegionMode      String @default("PREFER")
  sessionStickinessMode    String @default("DRAIN") // NONE, DRAIN
  drainGraceMinutes        Int    @default(20)

  // Track which server was last selected (for round-robin)
  lastSelectedKeyIndex Int @default(0)
  lastResolvedAccessKeyId String?
  lastResolvedServerId    String?
  lastResolvedAt          DateTime?
  pinnedAccessKeyId      String?
  pinnedServerId         String?
  pinnedAt               DateTime?
  pinExpiresAt           DateTime?

  // Subscription page theme (overrides global default)
  // Valid themes: dark, light, purple, blue, green, orange, pink, red, glass*
  subscriptionTheme String?

  // Subscription page cover image
  // coverImageType: upload, url, gradient
  coverImageType String?
  coverImage     String?

  // Contact links for subscription page (JSON array of up to 3 contacts)
  // Format: [{"type": "telegram", "value": "https://t.me/user"}, ...]
  contactLinks String?
  subscriptionWelcomeMessage String?
  sharePageEnabled           Boolean @default(true)

  // Key Auto-Rotation
  // When enabled, underlying access keys are periodically replaced
  // while keeping the subscription URL stable
  rotationEnabled  Boolean   @default(false)
  rotationInterval String    @default("NEVER") // NEVER, DAILY, WEEKLY, BIWEEKLY, MONTHLY
  rotationTriggerMode String @default("SCHEDULED") // SCHEDULED, USAGE, HEALTH, COMBINED
  rotationUsageThresholdPercent Int @default(85)
  rotateOnHealthFailure Boolean @default(false)
  lastRotatedAt    DateTime?
  nextRotationAt   DateTime?
  rotationCount    Int       @default(0) // Total rotations performed
  lastRoutingAlertAt DateTime?

  autoClearStalePins   Boolean @default(true)
  autoFallbackToPrefer Boolean @default(false)
  autoSkipUnhealthy    Boolean @default(false)
  routingAlertRules    String? // JSON configuration for per-alert channel delivery and cooldowns

  // App Integration
  welcomeMessage String?

  appliedTemplateId String?
  appliedTemplate DynamicKeyTemplate? @relation(fields: [appliedTemplateId], references: [id], onDelete: SetNull)

  accessKeys         AccessKey[]
  telegramLinkTokens TelegramLinkToken[]
  subscriptionEvents SubscriptionPageEvent[]
  routingEvents      DynamicRoutingEvent[]
  distributionLinks  AccessDistributionLink[]
  premiumSupportRequests TelegramPremiumSupportRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status, lastTrafficAt])
  @@index([appliedTemplateId])
}

model DynamicKeyTemplate {
  id          String @id @default(cuid())
  name        String
  description String?
  type        String @default("SELF_MANAGED")
  notes       String?
  dataLimitBytes BigInt?
  dataLimitResetStrategy String @default("NEVER")
  expirationType String @default("NEVER")
  durationDays Int?
  method String @default("chacha20-ietf-poly1305")
  serverTagsJson String @default("[]")
  loadBalancerAlgorithm String @default("IP_HASH")
  preferredServerIdsJson String @default("[]")
  preferredCountryCodesJson String @default("[]")
  preferredServerWeightsJson String @default("{}")
  preferredCountryWeightsJson String @default("{}")
  preferredRegionMode String @default("PREFER")
  sessionStickinessMode String @default("DRAIN")
  drainGraceMinutes Int @default(20)
  rotationEnabled Boolean @default(false)
  rotationInterval String @default("NEVER")
  rotationTriggerMode String @default("SCHEDULED")
  rotationUsageThresholdPercent Int @default(85)
  rotateOnHealthFailure Boolean @default(false)
  sharePageEnabled Boolean @default(true)
  subscriptionTheme String?
  subscriptionWelcomeMessage String?

  dynamicAccessKeys DynamicAccessKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicRoutingEvent {
  id String @id @default(cuid())
  dynamicAccessKeyId String
  dynamicAccessKey DynamicAccessKey @relation(fields: [dynamicAccessKeyId], references: [id], onDelete: Cascade)
  eventType String
  severity String @default("INFO") // INFO, WARNING, CRITICAL
  reason String
  fromKeyId String?
  fromKeyName String?
  fromServerId String?
  fromServerName String?
  toKeyId String?
  toKeyName String?
  toServerId String?
  toServerName String?
  metadata String?
  operatorNote String?
  createdAt DateTime @default(now())

  @@index([dynamicAccessKeyId, createdAt])
  @@index([eventType, createdAt])
}

model TelegramLinkToken {
  id               String     @id @default(cuid())
  token            String     @unique
  kind             String     @default("ACCESS_KEY_CONNECT")
  accessKeyId      String?
  accessKey        AccessKey? @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  dynamicAccessKeyId String?
  dynamicAccessKey DynamicAccessKey? @relation(fields: [dynamicAccessKeyId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByUserId  String?
  expiresAt        DateTime
  consumedAt       DateTime?
  consumedByChatId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([accessKeyId, expiresAt])
  @@index([dynamicAccessKeyId, expiresAt])
  @@index([userId, expiresAt])
  @@index([token, expiresAt])
}

model SubscriptionPageEvent {
  id                 String            @id @default(cuid())
  accessKeyId        String?
  accessKey          AccessKey?        @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  dynamicAccessKeyId String?
  dynamicAccessKey   DynamicAccessKey? @relation(fields: [dynamicAccessKeyId], references: [id], onDelete: Cascade)
  eventType          String
  source             String?
  platform           String?
  metadata           String?
  ip                 String?
  userAgent          String?
  createdAt          DateTime          @default(now())

  @@index([accessKeyId, createdAt])
  @@index([dynamicAccessKeyId, createdAt])
  @@index([eventType, createdAt])
}

model AccessDistributionLink {
  id                 String           @id @default(cuid())
  accessKeyId        String?
  accessKey          AccessKey?       @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  dynamicAccessKeyId String?
  dynamicAccessKey   DynamicAccessKey? @relation(fields: [dynamicAccessKeyId], references: [id], onDelete: Cascade)
  token              String           @unique
  label              String?
  note               String?
  expiresAt          DateTime
  maxUses            Int?
  currentUses        Int              @default(0)
  lastOpenedAt       DateTime?
  lastOpenedIp       String?
  createdAt          DateTime         @default(now())

  @@index([accessKeyId, expiresAt])
  @@index([dynamicAccessKeyId, expiresAt])
  @@index([token, expiresAt])
}

model AccessKeySlugHistory {
  id          String    @id @default(cuid())
  accessKeyId String
  accessKey   AccessKey @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  slug        String    @unique
  createdAt   DateTime  @default(now())

  @@index([accessKeyId, createdAt])
}

model TrafficLog {
  id          String    @id @default(cuid())
  accessKeyId String
  accessKey   AccessKey @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)

  // Historical Analytics (Phase 8)
  bytesUsed  BigInt // Cumulative at time of log
  deltaBytes BigInt @default(0) // Usage since last log

  recordedAt DateTime @default(now())

  @@index([accessKeyId, recordedAt])
}

// ============================================
// Connection Sessions (for device tracking)
// ============================================

model ConnectionSession {
  id          String    @id @default(cuid())
  accessKeyId String
  accessKey   AccessKey @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)

  // Session timing
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  lastActiveAt DateTime  @default(now())

  // Traffic during this session
  bytesUsed BigInt @default(0)

  // Is this session currently active?
  isActive    Boolean @default(true)
  endedReason String?

  @@index([accessKeyId, isActive])
  @@index([accessKeyId, startedAt])
  @@index([isActive, lastActiveAt])
}

// ============================================
// Archived Keys (for expired/deleted/depleted keys)
// ============================================

model ArchivedKey {
  id            String  @id @default(cuid())
  originalKeyId String // Original AccessKey ID
  outlineKeyId  String // ID from Outline API
  name          String
  email         String?
  telegramId    String?
  notes         String?

  // Server info (stored since original might be deleted)
  serverName     String
  serverLocation String?

  // Access key details
  accessUrl String?

  // Traffic data
  dataLimitBytes BigInt?
  usedBytes      BigInt  @default(0)

  // Expiration info
  expirationType String
  expiresAt      DateTime?
  durationDays   Int?

  // Archive reason: EXPIRED, DEPLETED, DELETED, DISABLED
  archiveReason String

  // Status at time of archival
  originalStatus String

  // Timestamps
  firstUsedAt DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime // Original creation date
  archivedAt  DateTime  @default(now())

  // Auto-delete after 3 months
  deleteAfter DateTime

  @@index([archiveReason])
  @@index([archivedAt])
  @@index([deleteAfter])
}

// ============================================
// Health Monitoring
// ============================================

model HealthCheck {
  id       String @id @default(cuid())
  serverId String @unique
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  isEnabled          Boolean @default(true)
  checkIntervalMins  Int     @default(5)
  notifyCooldownMins Int     @default(30)
  latencyThresholdMs Int     @default(500)

  // Valid lastStatus: UP, DOWN, SLOW, UNKNOWN
  lastStatus     String    @default("UNKNOWN")
  lastLatencyMs  Int?
  lastCheckedAt  DateTime?
  lastNotifiedAt DateTime?

  uptimePercent    Float @default(100)
  totalChecks      Int   @default(0)
  successfulChecks Int   @default(0)
  failedChecks     Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServerMetric {
  id       String @id @default(cuid())
  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  cpuPercent    Float?
  memoryPercent Float?
  diskPercent   Float?
  bytesIn       BigInt?
  bytesOut      BigInt?
  activeKeys    Int?

  recordedAt DateTime @default(now())

  @@index([serverId, recordedAt])
}

// ============================================
// Notifications
// ============================================

model NotificationChannel {
  id       String  @id @default(cuid())
  type     String // Valid: TELEGRAM, EMAIL, WEBHOOK
  name     String
  config   String // JSON config (bot token, chat ID, etc.)
  events   String // JSON array of NotificationEvent
  isActive Boolean @default(true)

  deliveries NotificationDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationDelivery {
  id            String               @id @default(cuid())
  channelId     String?
  channel       NotificationChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  event         String
  message       String
  payload       String?
  payloadMode   String               @default("WRAPPED") // WRAPPED, RAW
  cooldownKey   String?
  status        String               @default("PENDING") // PENDING, PROCESSING, RETRYING, SUCCESS, FAILED
  attemptCount  Int                  @default(0)
  maxAttempts   Int                  @default(5)
  nextAttemptAt DateTime             @default(now())
  lastAttemptAt DateTime?
  processedAt   DateTime?
  lastError     String?

  // Optional relation to access key
  accessKeyId String?
  accessKey   AccessKey? @relation(fields: [accessKeyId], references: [id], onDelete: SetNull)
  sourceLogId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([channelId])
  @@index([accessKeyId])
  @@index([sourceLogId])
  @@index([createdAt])
  @@index([channelId, event, cooldownKey, createdAt])
}

model BackupVerification {
  id             String   @id @default(cuid())
  filename       String
  status         String
  triggeredBy    String?
  fileSizeBytes  BigInt
  fileHashSha256 String?
  restoreReady   Boolean  @default(false)
  integrityCheck String?
  tableCount     Int?
  accessKeyCount Int?
  userCount      Int?
  error          String?
  details        String?
  verifiedAt     DateTime @default(now())

  @@index([filename, verifiedAt])
  @@index([verifiedAt])
}

model NotificationLog {
  id        String   @id @default(cuid())
  channelId String?
  event     String
  message   String
  status    String // SUCCESS, FAILED
  error     String?
  sentAt    DateTime @default(now())

  // Optional relation to access key
  accessKeyId String?
  accessKey   AccessKey? @relation(fields: [accessKeyId], references: [id], onDelete: SetNull)
}

model Incident {
  id                   String    @id @default(cuid())
  sourceType           String    @default("SERVER_HEALTH") // SERVER_HEALTH, MANUAL
  serverId             String?
  title                String
  summary              String
  severity             String    @default("warning") // critical, warning, info
  status               String    @default("OPEN") // OPEN, ACKNOWLEDGED, RESOLVED
  healthStatus         String?
  countryCode          String?
  affectedKeyCount     Int       @default(0)
  affectedUserCount    Int       @default(0)
  assignedUserId       String?
  assignedUserEmail    String?
  acknowledgedByUserId String?
  acknowledgedByEmail  String?
  resolvedByUserId     String?
  resolvedByEmail      String?
  notes                String?
  metadata             String?
  openedAt             DateTime  @default(now())
  lastSeenAt           DateTime  @default(now())
  acknowledgedAt       DateTime?
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  events IncidentEvent[]

  @@index([status, severity])
  @@index([serverId, status])
  @@index([openedAt])
}

model IncidentEvent {
  id                String   @id @default(cuid())
  incidentId        String
  incident          Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type              String // OPENED, STATUS_CHANGED, ACKNOWLEDGED, ASSIGNED, NOTE, RESOLVED, NOTIFICATION
  severity          String?
  title             String
  message           String?
  details           String?
  notificationLogId String?
  actorUserId       String?
  actorEmail        String?
  createdAt         DateTime @default(now())

  @@index([incidentId, createdAt])
  @@index([notificationLogId])
}

// ============================================
// Settings & Misc
// ============================================

model Settings {
  key   String @id
  value String // JSON value

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String? // JSON
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action, ip, createdAt])
}

// ============================================
// Type Definitions (for application-level validation)
// ============================================
// 
// Role values: ADMIN, STAFF, VIEWER
// KeyStatus values: ACTIVE, DISABLED, EXPIRED, DEPLETED, PENDING
// ExpirationType values: NEVER, FIXED_DATE, DURATION_FROM_CREATION, START_ON_FIRST_USE
// DakType values: SELF_MANAGED, MANUAL
// HealthStatus values: UP, DOWN, SLOW, UNKNOWN
// NotificationType values: TELEGRAM, EMAIL, WEBHOOK

// ============================================
// Access Key Templates
// ============================================

model KeyTemplate {
  id          String  @id @default(cuid())
  name        String // Template name (e.g., "Standard 30 Day")
  description String?

  // Key Configuration
  namePrefix             String? // Prefix for generated keys
  slugPrefix             String?
  dataLimitBytes         BigInt?
  dataLimitResetStrategy String  @default("NEVER")
  expirationType         String  @default("NEVER")
  durationDays           Int? // For DURATION_FROM_CREATION or START_ON_FIRST_USE
  method                 String  @default("chacha20-ietf-poly1305")
  subscriptionTheme      String?
  subscriptionWelcomeMessage String?
  sharePageEnabled       Boolean @default(true)
  clientLinkEnabled      Boolean @default(true)
  telegramDeliveryEnabled Boolean @default(true)
  autoDisableOnLimit     Boolean @default(true)
  autoDisableOnExpire    Boolean @default(true)
  autoArchiveAfterDays   Int     @default(0)
  quotaAlertThresholds   String  @default("80,90")
  autoRenewPolicy        String  @default("NONE")
  autoRenewDurationDays  Int?

  // Customization
  notes String? // Default notes

  // Default server (optional)
  serverId String?
  server   Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Security & Access Control
// ============================================

model SecurityRule {
  id String @id @default(cuid())

  // Rule Type: ALLOW (Whitelist) or BLOCK (Blacklist)
  type String @default("BLOCK")

  // Target: IP, CIDR, COUNTRY
  // Valid: IP, CIDR, COUNTRY
  targetType String

  // Value: 192.168.1.1, 10.0.0.0/24, US, CN
  targetValue String

  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, targetType])
}

model AdminLoginRestriction {
  id                String   @id @default(cuid())
  ip                String   @unique
  restrictionType   String
  attemptedEmail    String?
  failureCount      Int      @default(0)
  firstFailedAt     DateTime
  lastFailedAt      DateTime
  expiresAt         DateTime
  isActive          Boolean  @default(true)
  source            String   @default("APP")
  lastAlertSentAt   DateTime?
  lastFail2banEventAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive, expiresAt])
  @@index([restrictionType, isActive, expiresAt])
}

// ============================================
// Analytics & Usage Tracking
// ============================================

model UsageSnapshot {
  id String @id @default(cuid())

  // Optional server reference (for server-level aggregates)
  serverId String?

  // Optional key reference (for per-key snapshots)
  keyId String?

  // Key type: ACCESS_KEY or DYNAMIC_KEY
  keyType String?

  // Cumulative usage in bytes at this point in time
  usedBytes BigInt

  // Delta since last snapshot (calculated by worker)
  deltaBytes BigInt @default(0)

  createdAt DateTime @default(now())

  @@index([keyId, createdAt])
  @@index([serverId, createdAt])
  @@index([createdAt])
}

// ============================================
// Background Worker Coordination
// ============================================

model WorkerLock {
  id String @id @default("usage-snapshot-worker")

  // Worker that holds the lock
  workerId String

  // Lock acquisition time
  lockedAt DateTime @default(now())

  // Lock expiration (auto-release if worker crashes)
  expiresAt DateTime

  // Last heartbeat from the worker
  heartbeatAt DateTime @default(now())
}

// ============================================
// Two-Factor Authentication (2FA)
// ============================================

model TotpSecret {
  id     String @id @default(cuid())
  userId String @unique

  // Encrypted TOTP secret (base32 encoded, then encrypted)
  encryptedSecret String

  // Whether 2FA has been verified/enabled
  verified Boolean @default(false)

  // Track verification attempts (for rate limiting)
  lastAttemptAt DateTime?
  attemptCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecoveryCode {
  id     String @id @default(cuid())
  userId String

  // Hashed recovery code (bcrypt)
  codeHash String

  // When was this code used (null = not used)
  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// WebAuthn Passkeys
// ============================================

model WebAuthnCredential {
  id     String @id @default(cuid())
  userId String

  // WebAuthn credential data
  credentialId String @unique // Base64 encoded
  publicKey    String // Base64 encoded COSE public key
  counter      Int    @default(0)

  // Credential metadata
  deviceType String? // platform, cross-platform
  transports String? // JSON array: ["usb", "nfc", "ble", "internal"]

  // User-friendly name for the credential
  name String @default("Security Key")

  // Track last use
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// Security Probes (TLS/Certificate Monitoring)
// ============================================

model SecurityProbe {
  id       String @id @default(cuid())
  serverId String @unique

  // TLS/Connection details
  scheme      String? // http, https
  tlsVersion  String? // TLSv1.2, TLSv1.3
  cipherSuite String?

  // Certificate details
  certSubject  String?
  certIssuer   String?
  certExpiry   DateTime?
  certDaysLeft Int?

  // Security headers
  hasHsts    Boolean @default(false)
  hstsMaxAge Int?

  // Probe result
  // Valid: OK, CERT_EXPIRING, CERT_EXPIRED, TLS_ERROR, CONNECTION_ERROR
  result       String  @default("UNKNOWN")
  errorMessage String?

  // Timestamps
  lastCheckedAt DateTime?
  nextCheckAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Dashboard Security Settings
// ============================================

model DashboardSecurityProbe {
  id String @id @default("dashboard-security")

  // Current dashboard URL being probed
  dashboardUrl String?

  // TLS/Connection details
  scheme     String? // http, https
  tlsVersion String?

  // Security headers
  hasHsts            Boolean @default(false)
  hstsMaxAge         Int?
  hasSecureCookies   Boolean @default(false)
  hasHttpOnlyCookies Boolean @default(false)
  hasSameSiteCookies Boolean @default(false)

  // Content Security Policy
  hasCsp        Boolean @default(false)
  cspDirectives String? // JSON

  // Other headers
  hasXFrameOptions       Boolean @default(false)
  hasXContentTypeOptions Boolean @default(false)

  // Probe result
  result       String  @default("UNKNOWN")
  errorMessage String?

  // Overall security score (0-100)
  securityScore Int @default(0)

  lastCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Monthly Usage Reports
// ============================================

model Report {
  id String @id @default(cuid())

  // Report metadata
  name   String // e.g., "Monthly Report - January 2026"
  type   String @default("MONTHLY") // MONTHLY, WEEKLY, CUSTOM
  status String @default("GENERATING") // GENERATING, READY, FAILED

  // Date range covered by this report
  periodStart DateTime
  periodEnd   DateTime

  // Report content (stored as JSON string)
  // Contains aggregated data: per-server totals, per-key usage, etc.
  reportData String? // JSON blob

  // Summary stats (for quick display without parsing full data)
  totalServers    Int    @default(0)
  totalKeys       Int    @default(0)
  totalBytesUsed  BigInt @default(0)
  totalDeltaBytes BigInt @default(0) // Usage during the period

  // File reference for CSV download
  csvFileName String?

  // Who generated the report
  generatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduledRuns ScheduledReportRun[]

  @@index([periodStart, periodEnd])
  @@index([status])
}

model ScheduledReportRun {
  id             String    @id @default(cuid())
  reportId       String?
  report         Report?   @relation(fields: [reportId], references: [id], onDelete: SetNull)
  frequency      String
  status         String    @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED, SKIPPED
  triggeredBy    String?
  periodStart    DateTime
  periodEnd      DateTime
  summaryMessage String?
  configSnapshot String?
  error          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  deliveries ScheduledReportDelivery[]

  @@index([status, createdAt])
  @@index([createdAt])
}

model ScheduledReportDelivery {
  id                     String             @id @default(cuid())
  runId                  String
  run                    ScheduledReportRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  channelId              String?
  channelName            String
  channelType            String
  status                 String             @default("QUEUED") // QUEUED, SUCCESS, FAILED, SKIPPED
  notificationDeliveryId String?            @unique
  lastError              String?
  deliveredAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([runId, createdAt])
  @@index([status, createdAt])
}
